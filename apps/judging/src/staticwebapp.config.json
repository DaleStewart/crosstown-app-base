{
  "platform": { "apiRuntime": "node:18" },
  "auth": {
    "rolesSource": "/api/GetRoles",
    "identityProviders": {
      "github": {
        "registration": {
          "clientIdSettingName": "GITHUB_CLIENT_ID",
          "clientSecretSettingName": "GITHUB_CLIENT_SECRET"
        }
      }
    }
  },
  "routes": [
    { "route": "/judge.html",     "allowedRoles": ["authenticated"] },
    { "route": "/admin.html",     "allowedRoles": ["admin"] },
    { "route": "/api/teams",      "methods": ["POST"], "allowedRoles": ["admin"] },
    { "route": "/api/teams",      "methods": ["GET"],  "allowedRoles": ["authenticated"] },
    { "route": "/api/myscores",   "allowedRoles": ["authenticated"] },
    { "route": "/api/score",      "allowedRoles": ["authenticated"] },
    { "route": "/api/leaderboard","allowedRoles": ["authenticated"] },
    { "route": "/api/lock",       "allowedRoles": ["admin"] },
    { "route": "/api/export",     "allowedRoles": ["admin"] },
    { "route": "/api/logins",     "allowedRoles": ["admin"] }
  ],
  "responseOverrides": {
    "401": { "redirect": "/.auth/login/github", "statusCode": 302 }
  },
  "globalHeaders": {
    "Cache-Control": "no-store",
    "X-Frame-Options": "DENY",
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "strict-origin-when-cross-origin",
    "Content-Security-Policy": "default-src 'self'; style-src 'self' https://cdn.jsdelivr.net 'unsafe-inline'; font-src https://cdn.jsdelivr.net; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; img-src 'self' data:; connect-src 'self'"
  }
}
