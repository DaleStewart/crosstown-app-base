# MTA AI Hackathon Accelerator — environment template
# Copy to .env (gitignored) for local dev. azd populates these from Bicep outputs in deployed envs.

# --- Azure / Foundry ---
AZURE_SUBSCRIPTION_ID=
AZURE_LOCATION=eastus2
AZURE_RESOURCE_GROUP=

# Foundry project (azd populates after provision)
AZURE_AI_FOUNDRY_PROJECT_ENDPOINT=
AZURE_AI_FOUNDRY_PROJECT_NAME=

# Model deployments (names must match infra/modules/foundry.bicep)
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4.1
AZURE_OPENAI_REALTIME_DEPLOYMENT=gpt-4o-realtime-preview

# --- Voice provider switch ---
# foundry_realtime | speech_services
VOICE_PROVIDER=foundry_realtime

# Speech Services (used only when VOICE_PROVIDER=speech_services)
AZURE_SPEECH_ENDPOINT=
AZURE_SPEECH_REGION=eastus2

# --- Azure AI Search ---
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_INDEX_LOGS=mta-logs
AZURE_SEARCH_INDEX_RUNBOOKS=mta-runbooks

# --- Cosmos DB (NoSQL) ---
AZURE_COSMOS_ENDPOINT=
AZURE_COSMOS_DATABASE=mta
AZURE_COSMOS_CONTAINER_INCIDENTS=incidents
AZURE_COSMOS_CONTAINER_CONVERSATIONS=conversations

# --- Postgres (extension 09 only; idle in skeleton) ---
AZURE_POSTGRES_HOST=
AZURE_POSTGRES_DB=mta_legacy
AZURE_POSTGRES_USER=

# --- Observability ---
APPLICATIONINSIGHTS_CONNECTION_STRING=
OTEL_SERVICE_NAME=mta-orchestrator

# --- Service URLs (set by azd / ACA) ---
LOG_ANALYST_URL=http://localhost:8001
ORCHESTRATOR_URL=http://localhost:8000

# --- Local dev only ---
USE_LOCAL_AUTH=false
